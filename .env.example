# Prisma / PostgreSQL
# Supabase + Vercel (recommended):
# - DATABASE_URL: use Supabase pooler URL (port 6543, with sslmode=require)
# - DIRECT_URL: use direct node URL (port 5432, with sslmode=require)
#
# VPS PostgreSQL (later):
# - Set DATABASE_URL and DIRECT_URL to your VPS PostgreSQL URL

DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres?sslmode=require"

# Auth
AUTH_SECRET="replace-with-strong-random-string"

# Optional (used in metadata/sitemap)
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"
