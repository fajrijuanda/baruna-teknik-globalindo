generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User Admin untuk Login Dashboard
model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Hashed
  name      String?
  role      String   @default("admin") // "superadmin" | "admin"
  createdAt DateTime @default(now())
}

// Kategori Produk (Misal: Industrial Pump, Valve, Sparepart)
model Category {
  id        String    @id @default(cuid())
  name      Json      // { en: string, id: string }
  slug      String    @unique // Untuk URL SEO Friendly
  products  Product[]
}

// Data Produk Utama
model Product {
  id          String   @id @default(cuid())
  title       Json     // { en: string, id: string }
  slug        String   @unique
  description Json     @db.Json // { en: string, id: string }
  specifications Json? @db.Json // { en: string, id: string } or distinct structure
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  images      Image[]
  isFeatured  Boolean  @default(false) // Untuk tampil di Home
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Gambar Produk (Support Multi Image)
model Image {
  id        String  @id @default(cuid())
  url       String
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// Client / Partner Logos
model Client {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String
  website   String?
  isFeatured Boolean @default(true)
  createdAt DateTime @default(now())

}

// Dynamic Page Content (Key-Value Store for Page Settings)
model PageContent {
  id        String   @id @default(cuid())
  page      String   // e.g., "home", "about", "contact"
  section   String   // e.g., "hero", "vision", "info"
  content   Json     // Flexible JSON storage for text/images
  updatedAt DateTime @updatedAt

  @@unique([page, section]) // Ensure one content entry per section per page
}


// Visitor Tracking
model Visitor {
  id        String   @id @default(cuid())
  ipAddress String?
  userAgent String?
  path      String?  
  createdAt DateTime @default(now())
}

// Admin Activity Logging
model ActivityLog {
  id        String   @id @default(cuid())
  action    String   // e.g., "CREATE", "UPDATE", "DELETE"
  entity    String   // e.g., "Product", "Category"
  details   String   // Description of the action
  createdAt DateTime @default(now())
}
